# LLM — Ollama running locally on port 11434 (always)
OLLAMA_BASE_URL=http://localhost:11434

# Model routed through local Ollama (cloud-backed model)
OLLAMA_MODEL=qwen3.5:cloud

# Embeddings (always local). Multilingual model so EN queries match ZH/other-language docs.
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# App
# REQUIRED: must be a strong random value (>= 32 chars). The app refuses to start
# with a default/weak value. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
DATABASE_URL=sqlite:///./docmind.db
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db

# CORS
FRONTEND_URL=http://localhost:5173
